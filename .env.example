# ============================================================
#  Smart WhatsApp AI Agent — Environment Variables
#  Copy this file to .env and fill in your values.
#  Never commit your actual .env file to GitHub!
# ============================================================

# ── WhatsApp ─────────────────────────────────────────────────
# Your WhatsApp Business API token (from 360dialog / Meta Cloud API)
WHATSAPP_API_TOKEN=your_whatsapp_api_token_here

# Your own WhatsApp number (used to filter messages — optional)
# Format: international without + (e.g. 201012345678)
MY_WHATSAPP_NUMBER=your_number_here

# ── OpenAI ───────────────────────────────────────────────────
# Required for GPT-o3 (AI Agent language model)
OPENAI_API_KEY=sk-...

# ── Zep Memory ───────────────────────────────────────────────
# Long-term conversation memory for the AI Agent
# Get yours at: https://www.getzep.com/
ZEP_API_KEY=your_zep_api_key_here
ZEP_API_URL=https://api.getzep.com

# ── Pinecone (RAG Vector Database) ───────────────────────────
# Used to store and search your knowledge base documents
# Get yours at: https://www.pinecone.io/
PINECONE_API_KEY=your_pinecone_api_key_here
PINECONE_ENVIRONMENT=us-east-1        # e.g. us-east-1, eu-west-1
PINECONE_INDEX_NAME=whatsapp-agent-kb

# ── Cohere (Embeddings for RAG) ───────────────────────────────
# Used to convert documents into vector embeddings for Pinecone
# Get yours at: https://dashboard.cohere.com/
COHERE_API_KEY=your_cohere_api_key_here

# ── Google (Gmail + Calendar) ────────────────────────────────
# OAuth 2.0 credentials from Google Cloud Console
# Scopes needed: gmail.readonly, gmail.compose, calendar
GOOGLE_CLIENT_ID=your_google_client_id_here
GOOGLE_CLIENT_SECRET=your_google_client_secret_here
GOOGLE_REDIRECT_URI=http://localhost:5678/rest/oauth2-credential/callback

# ── X.com / Twitter ──────────────────────────────────────────
# API credentials from https://developer.twitter.com/
TWITTER_API_KEY=your_twitter_api_key_here
TWITTER_API_SECRET=your_twitter_api_secret_here
TWITTER_ACCESS_TOKEN=your_twitter_access_token_here
TWITTER_ACCESS_TOKEN_SECRET=your_twitter_access_token_secret_here

# ── n8n General ──────────────────────────────────────────────
# Only needed if you are self-hosting n8n
N8N_BASIC_AUTH_USER=admin
N8N_BASIC_AUTH_PASSWORD=changeme
N8N_HOST=localhost
N8N_PORT=5678
N8N_PROTOCOL=http
